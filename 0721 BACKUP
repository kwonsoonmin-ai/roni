<script>
    // =========================================================
    // 🚨 자바스크립트 스크립트 시작
    // =========================================================
    
    const APP_CONFIG = {
        version: 'v2.1', 
        notice: '경남담당 전용플래너'
    };

    function getNowStamp() {
        const now = new Date();
        const y = now.getFullYear();
        const m = String(now.getMonth() + 1).padStart(2, '0');
        const d = String(now.getDate()).padStart(2, '0');
        const hh = String(now.getHours()).padStart(2, '0');
        const mm = String(now.getMinutes()).padStart(2, '0');
        return `${y}-${m}-${d} ${hh}:${mm}`;
    }

    function updateAppMeta() {
        const metaText = `${APP_CONFIG.notice} / 버전 ${APP_CONFIG.version}`;
        const printText = `출력일시: ${getNowStamp()}`;

        const meta = document.getElementById('appMeta');
        const footer = document.getElementById('printFooter');
        if (meta) meta.innerText = metaText;
        if (footer) footer.innerText = printText;
    }

    function initSecurity() {
        // 보안 검사 없이 무조건 대시보드 화면을 보이게 함
        document.getElementById('mainAppContainer').style.display = 'flex'; 
        updateAppMeta();
    }

    function fn(num) {
        if (isNaN(num) || num === "" || num === null || num === undefined) return "0";
        return Number(num).toLocaleString('ko-KR');
    }

    function cleanNumber(str) {
        if (str === null || str === undefined) return 0;
        const s = String(str).replace(/,/g, '').replace(/원/g, '').trim();
        if (s === '' || s === '-') return 0;
        const m = s.match(/-?\d+(?:\.\d+)?/);
        return m ? Number(m[0]) : 0;
    }

    function parseExcelTSV(text) {
        let rows = [];
        let currentRow = [];
        let currentCell = '';
        let inQuotes = false;

        for (let i = 0; i < text.length; i++) {
            let char = text[i];

            if (inQuotes) {
                if (char === '"' && text[i + 1] === '"') {
                    currentCell += '"';
                    i++;
                } else if (char === '"') {
                    inQuotes = false;
                } else {
                    currentCell += char;
                }
            } else {
                if (char === '"') {
                    inQuotes = true;
                } else if (char === '\t') {
                    currentRow.push(currentCell.trim());
                    currentCell = '';
                } else if (char === '\n') {
                    currentRow.push(currentCell.trim());
                    rows.push(currentRow);
                    currentRow = [];
                    currentCell = '';
                } else if (char === '\r') {
                } else {
                    currentCell += char;
                }
            }
        }

        if (currentCell || currentRow.length > 0) {
            currentRow.push(currentCell.trim());
            rows.push(currentRow);
        }

        return rows;
    }

    function extractTextFromHtml(htmlString) {
        if (!htmlString) return '';
        let processedHtml = String(htmlString)
            .replace(/<br\s*[\/]?>/gi, '\n')                  
            .replace(/<\/p>/gi, '\n')                      
            .replace(/<\/div>/gi, '\n')
            .replace(/<\/li>/gi, '\n')
            .replace(/<li[^>]*>/gi, '\n');                 
        
        let tempDiv = document.createElement('div');
        tempDiv.innerHTML = processedHtml;
        let text = tempDiv.innerText || tempDiv.textContent || '';
        return text.replace(/[ \t]*\n[ \t]*/g, '\n').replace(/\n{2,}/g, '\n').trim();
    }

    function parseClipboardHtmlToMatrix(htmlText) {
        try {
            const doc = new DOMParser().parseFromString(htmlText, 'text/html');
            const table = doc.querySelector('table');
            if (table) {
                const rows = Array.from(table.querySelectorAll('tr')).map(tr =>
                    Array.from(tr.querySelectorAll('th,td')).map(td => extractTextFromHtml(td.innerHTML))
                ).filter(r => r.some(v => v));
                if (rows.length) return rows;
            }
            const bodyText = extractTextFromHtml(doc.body.innerHTML);
            if (bodyText) return parseTextToMatrix(bodyText);
        } catch (e) {}
        return [];
    }

    function parseClipboardHtmlTable(htmlText) {
        try {
            const doc = new DOMParser().parseFromString(htmlText, 'text/html');
            const table = doc.querySelector('table');
            if (!table) return [];
            return Array.from(table.querySelectorAll('tr')).map(tr =>
                Array.from(tr.querySelectorAll('th,td')).map(td => extractTextFromHtml(td.innerHTML))
            ).filter(row => row.some(v => v !== ''));
        } catch (e) {
            return [];
        }
    }

    function parseTextToMatrix(text) {
        const lines = String(text || '').replace(/\r/g, '').split('\n');
        return lines.map(line => {
            if (line.includes('\t')) return line.split('\t').map(v => v.trim());
            return [line.trim()];
        }).filter(row => row.some(v => v !== ''));
    }

    function parseClipboardTextToMatrix(text) {
        return String(text || '')
            .replace(/\r/g, '')
            .split('\n')
            .map(line => line.split('\t'))
            .filter(row => row.some(v => String(v).trim() !== ''));
    }

    const SHEET_ROWS = 60;
    const SHEET_COLS = 12;
    let activeSheetCell = { row: 0, col: 0 };

    function colLabel(n) {
        let s = '';
        let x = n + 1;
        while (x > 0) {
            const m = (x - 1) % 26;
            s = String.fromCharCode(65 + m) + s;
            x = Math.floor((x - 1) / 26);
        }
        return s;
    }

    function initInputSheet() {
        const head = document.getElementById('inputSheetHead');
        const body = document.getElementById('inputSheetBody');
        if (!head || !body) return;

        let headHtml = '<tr><th class="corner"></th>';
        for (let c = 0; c < SHEET_COLS; c++) headHtml += `<th>${colLabel(c)}</th>`;
        headHtml += '</tr>';
        head.innerHTML = headHtml;

        let bodyHtml = '';
        for (let r = 0; r < SHEET_ROWS; r++) {
            bodyHtml += `<tr><th>${r + 1}</th>`;
            for (let c = 0; c < SHEET_COLS; c++) {
                bodyHtml += `<td contenteditable="true" data-row="${r}" data-col="${c}"></td>`;
            }
            bodyHtml += '</tr>';
        }
        body.innerHTML = bodyHtml;

        body.querySelectorAll('td').forEach(td => {
            td.addEventListener('focus', () => setActiveSheetCell(td));
            td.addEventListener('click', () => setActiveSheetCell(td));
            td.addEventListener('input', syncRawFromSheet);
            td.addEventListener('paste', handleSheetPaste);
        });
    }

    function setActiveSheetCell(td) {
        document.querySelectorAll('#inputSheetBody td.active-cell').forEach(el => el.classList.remove('active-cell'));
        td.classList.add('active-cell');
        activeSheetCell = {
            row: parseInt(td.dataset.row || '0', 10),
            col: parseInt(td.dataset.col || '0', 10)
        };
    }

    function getSheetCell(r, c) {
        return document.querySelector(`#inputSheetBody td[data-row="${r}"][data-col="${c}"]`);
    }

    function handleSheetPaste(e) {
        const textData = e.clipboardData ? e.clipboardData.getData('text/plain') : '';
        const htmlData = e.clipboardData ? e.clipboardData.getData('text/html') : '';
        let matrix = htmlData ? parseClipboardHtmlTable(htmlData) : [];
        if (!matrix.length) matrix = parseClipboardTextToMatrix(textData);
        if (!matrix.length) return;

        e.preventDefault();

        const startRow = activeSheetCell.row || 0;
        const startCol = activeSheetCell.col || 0;

        matrix.forEach((row, rIdx) => {
            row.forEach((val, cIdx) => {
                const cell = getSheetCell(startRow + rIdx, startCol + cIdx);
                if (cell) cell.innerText = String(val || '').trim();
            });
        });

        syncRawFromSheet();
    }

    function syncRawFromSheet() {
        const raw = document.getElementById('rawPasteArea');
        if (!raw) return;

        const lines = [];
        for (let r = 0; r < SHEET_ROWS; r++) {
            const rowVals = [];
            let lastUsed = -1;
            for (let c = 0; c < SHEET_COLS; c++) {
                const cell = getSheetCell(r, c);
                let val = cell ? (cell.innerText || cell.textContent).replace(/\u00a0/g, ' ').trim() : '';
                
                if (val.includes('\n') || val.includes('\r') || val.includes('"') || val.includes('\t')) {
                    val = '"' + val.replace(/"/g, '""') + '"';
                }
                
                rowVals.push(val);
                if (val !== '' && val !== '""') lastUsed = c;
            }
            if (lastUsed >= 0) lines.push(rowVals.slice(0, lastUsed + 1).join('\t'));
        }
        raw.value = lines.join('\n');
    }

    function clearInputSheet() {
        for (let r = 0; r < SHEET_ROWS; r++) {
            for (let c = 0; c < SHEET_COLS; c++) {
                const cell = getSheetCell(r, c);
                if (cell) {
                    cell.innerText = '';
                    cell.classList.remove('active-cell');
                }
            }
        }
        const raw = document.getElementById('rawPasteArea');
        if (raw) raw.value = '';
    }

    document.addEventListener('DOMContentLoaded', function() {
        initInputSheet();
        
        const raw = document.getElementById('rawPasteArea');
        if (raw) {
            raw.addEventListener('paste', function(e) {
                const htmlData = e.clipboardData ? e.clipboardData.getData('text/html') : '';
                if (htmlData) {
                    const matrix = parseClipboardHtmlToMatrix(htmlData);
                    if (matrix && matrix.length > 0) {
                        e.preventDefault();
                        const tsv = matrix.map(row => row.map(val => {
                            if (val.includes('\n') || val.includes('\r') || val.includes('"') || val.includes('\t')) {
                                return '"' + val.replace(/"/g, '""') + '"';
                            }
                            return val;
                        }).join('\t')).join('\n');
                        
                        const start = this.selectionStart;
                        const end = this.selectionEnd;
                        this.value = this.value.substring(0, start) + tsv + this.value.substring(end);
                        this.selectionStart = this.selectionEnd = start + tsv.length;
                    }
                }
            });
        }
    });

    let parsedData = {};
    let parsedModels = [];
    let optionCount = 0;
    let optionLabels = [];
    let gapBaseIndex = 0;
    let latestResults = [];

    function getKnownKey(text) {
        const norm = String(text).replace(/\s+/g, '');
        if (!norm) return null;

        if (norm.includes('체감구독료')) return '체감구독료(월)';
        if (norm.includes('정상구독료') || norm.includes('월구독료')) return '정상구독료(월)';
        if (norm.includes('프로모션할인')) return '프로모션할인(월)';
        if (norm.includes('결합할인')) return '결합할인(월)';
        if (norm.includes('선납할인')) return '선납할인(월)';
        if (norm.includes('캐시백') || norm.includes('캐쉬백') || norm.includes('현금지원')) return '캐시백';
        if (norm.includes('제휴카드월') || norm.includes('제휴카드할인') || norm.includes('카드할인월') || (norm.includes('제휴카드') && norm.includes('월'))) return '제휴카드(월)';
        if (norm.includes('제휴카드')) return '제휴카드';
        if (norm.includes('선납금액')) return '선납금액';
        if (norm.includes('선납시카드') || norm.includes('선납카드')) return '선납시카드혜택';
        
        if (norm.includes('정상가') || norm.includes('정상판매가') || norm.includes('정상가격')) return '정상가';
        if (norm.includes('행사가') || norm.includes('행사판매가') || (norm.includes('판매가') && !norm.includes('정상'))) return '행사가';
        if (norm.includes('특별할인') || norm.includes('즉시할인')) return '특별할인';
        if (norm.includes('결제금액') || norm.includes('최종결제')) return '결제금액';
        if (norm.includes('상품권')) return '상품권';
        if (norm.includes('멤버십') || norm.includes('멤버쉽') || norm.includes('포인트')) return '멤버십';
        
        if (norm.includes('특별혜택')) return '특별혜택';
        
        if (norm.includes('최종혜택금액') || norm.includes('최종혜택가') || norm.includes('최종혜택')) return '최종혜택금액';
        if (norm.includes('혜택합계') || norm.includes('총혜택') || norm.includes('총혜택금액')) return '혜택합계';
        if (norm.includes('계약개월') || norm.includes('계약기간') || norm.includes('개월수')) return '계약개월수';

        return null;
    }

    function populateGapBaseOptions() {
        const select = document.getElementById('gapBaseSelect');
        if (!select) return;
        select.innerHTML = Array.from({ length: optionCount }, (_, idx) =>
            `<option value="${idx}" ${idx === gapBaseIndex ? 'selected' : ''}>${idx + 1}안</option>`
        ).join('');
        select.value = String(gapBaseIndex);
    }

    function handleGapBaseChange() {
        const select = document.getElementById('gapBaseSelect');
        if (!select) return;
        gapBaseIndex = Number(select.value) || 0;
        gapBaseIndex = Math.min(gapBaseIndex, Math.max(0, optionCount - 1));
        populateGapBaseOptions();
        calculateAndRender();
    }

    function normalizeModelLine(text) {
        return String(text || '')
            .replace(/\s+/g, ' ')                
            .replace(/\s*\[구독\]/gi, ' [구독]') 
            .trim();
    }

    function formatModelCellBlock(text) {
        if (!text) return '-';
        const lines = String(text).split(/\r?\n/);
        
        const processed = lines.map(normalizeModelLine).filter(Boolean);
        return processed.length > 0 ? processed.join('\n') : '-';
    }

    function groupModelLines(lines, optionCount) {
        const cleaned = lines.map(normalizeModelLine).filter(Boolean);
        if (!cleaned.length) return Array.from({ length: optionCount }, () => '-');
        if (optionCount === 1) return [cleaned.join('\n')];

        const result = Array.from({ length: optionCount }, () => '-');
        const firstSubIdx = cleaned.findIndex(v => /\[구독\]/.test(v));

        if (firstSubIdx > 0) {
            result[0] = cleaned.slice(0, firstSubIdx).join('\n');
            const rest = cleaned.slice(firstSubIdx);

            if (optionCount === 2) {
                result[1] = rest.join('\n');
                return result;
            }

            const a = rest[0] || '';
            const b = rest[1] || '';
            const starts = [0];
            for (let i = 1; i < rest.length - 1; i++) {
                if (starts.length >= optionCount - 1) break;
                if (rest[i] === a && rest[i + 1] === b) starts.push(i);
            }

            if (starts.length === optionCount - 1) {
                for (let i = 0; i < optionCount - 1; i++) {
                    const s = starts[i];
                    const e = i + 1 < starts.length ? starts[i + 1] : rest.length;
                    result[i + 1] = rest.slice(s, e).join('\n');
                }
                return result;
            }

            const starts2 = [0];
            for (let i = 1; i < rest.length; i++) {
                if (starts2.length >= optionCount - 1) break;
                if (rest[i] === a) starts2.push(i);
            }
            if (starts2.length === optionCount - 1) {
                for (let i = 0; i < optionCount - 1; i++) {
                    const s = starts2[i];
                    const e = i + 1 < starts2.length ? starts2[i + 1] : rest.length;
                    result[i + 1] = rest.slice(s, e).join('\n');
                }
                return result;
            }

            let cursor = 0;
            for (let i = 1; i < optionCount; i++) {
                const remainingLines = rest.length - cursor;
                const remainingGroups = optionCount - i;
                const take = Math.max(1, Math.ceil(remainingLines / remainingGroups));
                result[i] = rest.slice(cursor, cursor + take).join('\n');
                cursor += take;
            }
            return result;
        }

        const a = cleaned[0] || '';
        const b = cleaned[1] || '';
        const starts = [0];
        for (let i = 1; i < cleaned.length - 1; i++) {
            if (starts.length >= optionCount) break;
            if (cleaned[i] === a && cleaned[i + 1] === b) starts.push(i);
        }
        if (starts.length === optionCount) {
            for (let i = 0; i < optionCount; i++) {
                const s = starts[i];
                const e = i + 1 < starts.length ? starts[i + 1] : cleaned.length;
                result[i] = cleaned.slice(s, e).join('\n');
            }
            return result;
        }

        const chunk = Math.ceil(cleaned.length / optionCount);
        for (let i = 0; i < cleaned.length; i++) {
            const idx = Math.min(optionCount - 1, Math.floor(i / chunk));
            const prev = result[idx] === '-' ? '' : result[idx] + '\n';
            result[idx] = prev + cleaned[i];
        }
        return result;
    }

    function iSKnownValueRow(text) {
        const known = [
            '정상가','행사가','특별할인','결제금액','캐시백','상품권','멤버십',
            '특별혜택','제휴카드','선택결제카드','선택결제카드명','선택결제카드설명',
            '혜택합계','최종혜택금액','정상구독료(월)','프로모션할인(월)','결합할인(월)',
            '선납할인(월)','제휴카드(월)','선납금액','선납시카드혜택','체감구독료(월)'
        ];
        const key = getKnownKey(String(text || ''));
        return !!key && known.includes(key);
    }

    function parseExcelData() {
        const rawText = document.getElementById("rawPasteArea").value;
        if (rawText.trim() === "") {
            alert("Data를 먼저 붙여넣어 주세요.");
            return;
        }

        const rows = parseExcelTSV(rawText).filter(r => r.some(c => String(c || '').trim() !== ''));
        parsedData = {};
        parsedModels = [];
        optionCount = 0;
        optionLabels = [];
        latestResults = [];

        if (!rows.length) {
            alert("붙여넣은 Data가 비어 있습니다.");
            return;
        }

        const headerTokens = rows[0].join(' ').match(/\d+안/g) || [];
        optionCount = headerTokens.length >= 2 ? headerTokens.length : Math.max(...rows.map(r => Math.max(0, r.length - 1)));

        let modelStart = -1;
        let modelEnd = -1;
        let modelRowIndex = -1;
        let detectedLastValueCol = 0;

        for (let i = 0; i < rows.length; i++) {
            const row = rows[i];
            const rowText = row.join(' ').trim().replace(/\s+/g, '');
            const firstCellNorm = String(row[0] || '').trim().replace(/\s+/g, '');
            if (rowText.includes('선택모델') || rowText.includes('모델명') || firstCellNorm.includes('선택모델')) {
                modelRowIndex = i;
                modelStart = i + 1;
                continue;
            }
            const identifiedKey = getKnownKey(String(row[0] || '').trim()) || getKnownKey(rowText);
            if (identifiedKey && row.length > 1) {
                let lastUsed = 0;
                row.slice(1).forEach((v, idx) => {
                    if (String(v || '').trim() !== '') lastUsed = idx + 1;
                });
                detectedLastValueCol = Math.max(detectedLastValueCol, lastUsed);
            }
            if (modelStart !== -1 && rowText && iSKnownValueRow(rows[i][0] || rowText)) {
                modelEnd = i;
                break;
            }
        }

        if (detectedLastValueCol > 0) optionCount = Math.min(optionCount, detectedLastValueCol);
        if (optionCount === 0) {
            alert("안(옵션) 열 데이터를 찾지 못했습니다.");
            return;
        }

        optionLabels = Array.from({ length: optionCount }, (_, i) => `${i + 1}안`);
        parsedModels = Array.from({ length: optionCount }, () => '-');

        if (modelRowIndex !== -1) {
            const modelRow = rows[modelRowIndex] || [];
            let directMapped = 0;

            if (modelRow.length > 1) {
                for (let c = 1; c <= optionCount; c++) {
                    const v = String(modelRow[c] || '').trim();
                    if (v) {
                        parsedModels[c - 1] = formatModelCellBlock(v);
                        directMapped++;
                    }
                }
            }

            if (directMapped === 0) {
                if (modelEnd === -1) modelEnd = rows.length;
                const modelLines = [];

                for (let i = modelStart; i < modelEnd; i++) {
                    const row = rows[i];
                    const nonEmpty = row.map(v => String(v || '').trim()).filter(Boolean);

                    if (row.length >= optionCount + 1) {
                        for (let c = 1; c <= optionCount; c++) {
                            const v = String(row[c] || '').trim();
                            if (v) {
                                const merged = parsedModels[c - 1] === '-' ? v : (parsedModels[c - 1] + '\n' + v);
                                parsedModels[c - 1] = formatModelCellBlock(merged);
                            }
                        }
                    } else if (nonEmpty.length) {
                        modelLines.push(...nonEmpty);
                    }
                }

                const directCount = parsedModels.filter(v => v !== '-' && v.trim()).length;
                if (directCount === 0 && modelLines.length) {
                    parsedModels = groupModelLines(modelLines, optionCount);
                }
            }
        }

        const valueStart = modelEnd !== -1 ? modelEnd : 0;
        for (let i = valueStart; i < rows.length; i++) {
            const row = rows[i];
            const firstCell = String(row[0] || '').trim();
            const rowText = row.join(' ').trim();
            if (!rowText) continue;

            const identifiedKey = getKnownKey(firstCell) || getKnownKey(rowText);
            if (!identifiedKey) continue;

            let nums = [];
            if (row.length > 1) {
                nums = row.slice(1, optionCount + 1).map(v => cleanNumber(v));
            } else {
                const pureText = rowText.replace(firstCell, '').trim();
                const extracted = pureText.match(/-?\d{1,3}(?:,\d{3})*(?:\.\d+)?/g) || [];
                nums = extracted.map(v => cleanNumber(v)).slice(0, optionCount);
            }
            parsedData[identifiedKey] = nums;
        }

        gapBaseIndex = Math.min(gapBaseIndex, Math.max(0, optionCount - 1));
        populateGapBaseOptions();
        calculateAndRender();
    }

    function getVal(key, idx) {
        return parsedData[key] && parsedData[key][idx] !== undefined ? parsedData[key][idx] : 0;
    }

    function hasVal(key, idx) {
        return parsedData[key] !== undefined && parsedData[key].length > idx;
    }

    function calculateAndRender() {
        let results = [];

        for (let i = 0; i < optionCount; i++) {
            const modelText = String(parsedModels[i] || '').trim();
            const modelHasSubscriptionTag = /\[구독\]/.test(modelText);

            const normalPrice = getVal('정상가', i);
            const eventPrice = getVal('행사가', i);
            const specialDc = getVal('특별할인', i);
            const cashback = getVal('캐시백', i);
            const voucher = getVal('상품권', i);
            const membership = getVal('멤버십', i);
            const specialBenefit = getVal('특별혜택', i);
            const cardBenefit = getVal('제휴카드', i);

            let subFee = getVal('정상구독료(월)', i);
            let promoDc = getVal('프로모션할인(월)', i);
            let comboDc = getVal('결합할인(월)', i);
            let preDc = getVal('선납할인(월)', i);
            let cardDcMonthly = getVal('제휴카드(월)', i);
            let preAmt = getVal('선납금액', i);
            let preCard = getVal('선납시카드혜택', i);
            const contractMonth = getVal('계약개월수', i) || 72;

            const payRaw = getVal('결제금액', i);
            const pay = hasVal('결제금액', i) ? payRaw : Math.max(0, eventPrice - specialDc);

            const benefitSumRaw = getVal('혜택합계', i);
            const benefitSum = hasVal('혜택합계', i) ? benefitSumRaw : (cashback + voucher + membership + specialBenefit + cardBenefit);

            const finalBenefitRaw = getVal('최종혜택금액', i);
            const finalBenefit = hasVal('최종혜택금액', i) ? finalBenefitRaw : Math.max(0, pay - benefitSum);

            let realSubRaw = getVal('체감구독료(월)', i);
            const realSub = hasVal('체감구독료(월)', i) ? realSubRaw : Math.max(0, subFee - promoDc - comboDc - preDc - cardDcMonthly);

            const sourceHasContent = (modelText && modelText !== '-') || 
                [normalPrice, eventPrice, specialDc, payRaw, cashback, voucher, membership, specialBenefit, cardBenefit, benefitSumRaw, finalBenefitRaw, subFee, promoDc, comboDc, preDc, cardDcMonthly, preAmt, preCard, realSubRaw].some(v => v !== 0);

            if (!modelHasSubscriptionTag) {
                subFee = 0; promoDc = 0; comboDc = 0; preDc = 0; cardDcMonthly = 0; preAmt = 0; preCard = 0; realSubRaw = 0;
            }

            const hasSubscription = modelHasSubscriptionTag && 
                (subFee > 0 || promoDc > 0 || comboDc > 0 || preDc > 0 || cardDcMonthly > 0 || preAmt > 0 || preCard > 0 || realSub > 0 || realSub < 0);

            const subscriptionAmount = hasSubscription ? Math.max(0, preAmt - preCard + (realSub * contractMonth)) : 0;
            const total = hasSubscription ? finalBenefit + subscriptionAmount : finalBenefit;
            const subscriptionShare = total > 0 ? (subscriptionAmount / total) : 0;
            const subscriptionDominant = subscriptionShare >= 0.7;

            results.push({
                header: optionLabels[i],
                model: modelText || '-',
                normalPrice, eventPrice, specialDc, pay, cashback, voucher,
                membership, specialBenefit, cardBenefit, benefitSum, finalBenefit, subFee,
                promoDc, comboDc, preDc, cardDcMonthly, preAmt, preCard,
                realSub, total, contractMonth, hasSubscription, sourceHasContent,
                subscriptionAmount, subscriptionShare, subscriptionDominant
            });
        }

        results = results.filter(item => item.sourceHasContent);

        if (!results.length) {
            results = [{
                header: '1안', model: '-', normalPrice: 0, eventPrice: 0, specialDc: 0, pay: 0,
                cashback: 0, voucher: 0, membership: 0, cardBenefit: 0, benefitSum: 0,
                finalBenefit: 0, subFee: 0, promoDc: 0, comboDc: 0, preDc: 0,
                cardDcMonthly: 0, preAmt: 0, preCard: 0, realSub: 0, total: 0,
                contractMonth: 72, hasSubscription: false
            }];
        }

        optionCount = results.length;
        optionLabels = results.map((_, idx) => `${idx + 1}안`);
        results = results.map((item, idx) => ({ ...item, header: optionLabels[idx] }));

        if (gapBaseIndex >= optionCount) gapBaseIndex = 0;
        populateGapBaseOptions();

        latestResults = results;
        renderQuoteTable(results);
        applyModelRowVisibility();
    }

