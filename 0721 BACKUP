    let checkedState = {};
    let currentCareTitle = '';

    function renderPrintSelectedCareTable() {
        const tbody = document.getElementById('printSelectedCareBody');
        const selectedItems = [];

        for (const key in checkedState) {
            const item = checkedState[key];
            if (item && item.checked) selectedItems.push(item);
        }

        if (!selectedItems.length) {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;">선택된 항목 없음</td></tr>';
            return;
        }

        tbody.innerHTML = selectedItems.map(item => `
            <tr>
                <td class="text-left">${item.category ? item.category + ' : ' : ''}${item.name}</td>
                <td>${item.period || '-'}</td>
                <td class="text-right">${item.price === 0 ? '별도 산정' : fn(item.price) + '원'}</td>
                <td class="text-left">${item.desc || '-'}</td>
            </tr>
        `).join('');
    }

    function calculateCareTotal() {
        let totalVal = 0;
        const selectedLines = [];

        for (const key in checkedState) {
            const item = checkedState[key];
            if (item && item.checked) {
                totalVal += item.price;
                const prefix = item.category ? `${item.category} : ` : '';
                selectedLines.push(`• ${prefix}${item.name} ${item.price === 0 ? '(별도 산정)' : '(' + fn(item.price) + '원)'}`);
            }
        }

        document.getElementById('selectedItemsList').innerText = selectedLines.length ? selectedLines.join('\n') : '선택된 항목 없음';
        document.getElementById('totalValue').innerText = fn(totalVal);
        renderPrintSelectedCareTable();
    }

    function toggleCheck(id, price, name, category, period, desc, cb, row) {
        checkedState[id] = cb.checked ? { checked: true, price: price, name: name, category: category, period: period, desc: desc } : false;
        if (cb.checked) row.classList.remove('disabled-row');
        else row.classList.add('disabled-row');
        calculateCareTotal();
    }

    function clearSelectedItems() {
        checkedState = {};
        document.querySelectorAll('#careTableBody input[type="checkbox"]').forEach(cb => {
            cb.checked = false;
            const row = cb.closest('tr');
            if (row) row.classList.add('disabled-row');
        });
        calculateCareTotal();
    }

    function changeTab(category, titleName, btn) {
        document.querySelectorAll('.tab-btn:not(.video-btn)').forEach(b => b.classList.remove('active'));
        if (btn) btn.classList.add('active');

        currentCareTitle = titleName;
        document.getElementById('dashboardTitle').innerText = '✨ 구독 Care 비용';

        const tbody = document.getElementById('careTableBody');
        tbody.innerHTML = '';

        careData[category].forEach(item => {
            const isChecked = !!(checkedState[item.id] && checkedState[item.id].checked);
            const tr = document.createElement('tr');
            if (!isChecked) tr.classList.add('disabled-row');

            const safeName = String(item.name).replace(/'/g, "\'");
            const safeTitle = String(titleName).replace(/'/g, "\'");
            const safePeriod = String(item.period).replace(/'/g, "\\'");
            const safeDesc = String(item.desc).replace(/'/g, "\\'");
            tr.innerHTML = `<td class="checkbox-cell"><input type="checkbox" style="width:18px;height:18px; cursor:pointer;" onchange="toggleCheck('${item.id}', ${item.price}, '${safeName}', '${safeTitle}', '${safePeriod}', '${safeDesc}', this, this.parentElement.parentElement)" ${isChecked ? 'checked' : ''}></td>
                <td class="text-left" style="color:#0056b3; font-weight:bold;">${item.name}</td><td>${item.period}</td>
                <td class="text-right" style="font-weight:bold;">${item.price === 0 ? "별도 산정" : fn(item.price) + "원"}</td><td class="text-left" style="font-size:11px; color:#555;">${item.desc}</td>`;
            tbody.appendChild(tr);
        });
    }

    function resetPrintModes() {
        document.body.classList.remove('print-estimate');
        document.body.classList.remove('print-care');
        document.body.classList.remove('print-all');
    }

    function applyAutoFitZoom() {
        const panel = document.getElementById('estimatePanel');
        const table = document.getElementById('quoteTable');
        if (!panel || !table) return;

        panel.style.zoom = '1'; 

        const A4_MAX_HEIGHT = 980;
        const printContentHeight = table.offsetHeight + 150;

        if (printContentHeight > A4_MAX_HEIGHT) {
            const zoomRatio = (A4_MAX_HEIGHT / printContentHeight) * 0.98;
            panel.style.zoom = zoomRatio;
        }
    }

    function removeAutoFitZoom() {
        const panel = document.getElementById('estimatePanel');
        if (panel) panel.style.zoom = '1'; 
    }

    function printEstimate() {
        updateAppMeta();
        resetPrintModes();
        document.body.classList.add('print-estimate');
        
        applyAutoFitZoom(); 

        setTimeout(() => {
            window.print();
            setTimeout(() => {
                resetPrintModes();
                removeAutoFitZoom(); 
            }, 300);
        }, 50);
    }

    function printCare() {
        updateAppMeta();
        resetPrintModes();
        document.body.classList.add('print-care');
        window.print();
        setTimeout(() => resetPrintModes(), 300);
    }

    function printAllPage() {
        updateAppMeta();
        resetPrintModes();
        document.body.classList.add('print-all');
        
        applyAutoFitZoom(); 

        setTimeout(() => {
            window.print();
            setTimeout(() => {
                resetPrintModes();
                removeAutoFitZoom(); 
            }, 300);
        }, 50);
    }

