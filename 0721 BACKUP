    function openCardQrModal(cardKey) {
        const data = cardData[cardKey];
        if(!data) return;
        
        document.getElementById('cardQrModalTitle').innerText = data.title;
        document.getElementById('cardQrModalPhone').innerText = '발급 ARS: ' + data.phone;
        document.getElementById('cardQrModalBenefits').innerHTML = data.benefits;
        
        const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&margin=0&data=${encodeURIComponent(data.url)}`;
        document.getElementById('cardQrImage').src = qrUrl;
        
        document.getElementById('cardQrModalOverlay').style.display = 'flex';
    }

    function closeCardQrModal(event) {
        if (event && event.target !== document.getElementById('cardQrModalOverlay') && event.target.tagName !== 'BUTTON') {
            return;
        }
        document.getElementById('cardQrModalOverlay').style.display = 'none';
        document.getElementById('cardQrImage').src = ''; 
    }

    window.onload = function() {
        const firstBtn = document.querySelector('.tab-btn');
        changeTab('tvCare', 'TV 케어', firstBtn);
        initSecurity();
    };

    let modelRowVisible = true;
    function applyModelRowVisibility() {
        const table = document.getElementById('quoteTable');
        const btn = document.getElementById('toggleModelBtn');
        if (!table || !btn) return;
        if (modelRowVisible) {
            table.classList.remove('hide-model-row');
            btn.textContent = '모델명 숨기기';
        } else {
            table.classList.add('hide-model-row');
            btn.textContent = '모델명 보이기';
        }
    }
    function toggleModelRowVisibility() {
        modelRowVisible = !modelRowVisible;
        applyModelRowVisibility();
    }

    // [RONi 특장점 팝업]
    function openRoniFeatureModal() {
        document.getElementById('roniFeatureOverlay').style.display = 'flex';
    }
    function closeRoniFeatureModal(event) {
        if (event && event.target !== document.getElementById('roniFeatureOverlay') && event.target.tagName !== 'BUTTON' && event.type !== 'click') return;
        document.getElementById('roniFeatureOverlay').style.display = 'none';
    }

    // [프리미엄 비주얼 세일즈 가이드 팝업]
    function openVisualGuideModal() {
        // 기존 3자 비교 팝업은 놔둔 채로 위에 띄웁니다.
        document.getElementById('visualGuideOverlay').style.display = 'flex';
    }
    function closeVisualGuideModal(event) {
        if (event && event.target !== document.getElementById('visualGuideOverlay') && event.target.tagName !== 'BUTTON' && !event.target.classList.contains('btn-close-visual') && event.type !== 'click') return;
        document.getElementById('visualGuideOverlay').style.display = 'none';
    }

    // [🛡️ RONi 구독 관리 팝업 및 이미지 전환 로직]
    function openRoniCareModal() {
        document.getElementById('roniCareOverlay').style.display = 'flex';
        // 모달 열 때 기본 첫 이미지(2.png)로 초기화 - 절대 경로 적용
        document.getElementById('roniCareMainImage').src = 'https://raw.githubusercontent.com/kwonsoonmin-ai/roni/main/2.png';
    }
    
    function closeRoniCareModal(event) {
        if (event && event.target !== document.getElementById('roniCareOverlay') && event.target.tagName !== 'BUTTON' && event.type !== 'click') return;
        document.getElementById('roniCareOverlay').style.display = 'none';
    }
    
    function changeCareImage(imageName) {
        // 클릭한 영역에 맞춰 이미지를 즉시 변경합니다.
        document.getElementById('roniCareMainImage').src = imageName;
    }
