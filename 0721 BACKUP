        rowDefs.forEach(def => {
            const tr = document.createElement('tr');
            if (def.rowClass) tr.className = def.rowClass;
            if (def.type === 'model') tr.classList.add('model-row');

            let html = '';
            if (def.key === 'gap') {
                html = `<td class="label-cell"><span id="gapLabelText">${def.label}</span></td>`;
            } else {
                html = `<td class="label-cell">${def.label}</td>`;
            }

            if (def.key === 'gap') {
                const baseTotal = results[gapBaseIndex] ? results[gapBaseIndex].total : 0;
                html += results.map((item, idx) => {
                    const dominantClass = item.subscriptionDominant ? ' subscription-dominant-cell' : '';
                    if (idx === gapBaseIndex) return `<td class="number-cell${dominantClass}">기준안</td>`;
                    return `<td class="number-cell${dominantClass}">${fn(item.total - baseTotal)}</td>`;
                }).join('');
            } else if (def.type === 'model') {
                html += results.map((item, idx) => {
                    const dominantClass = item.subscriptionDominant ? ' subscription-dominant-cell' : '';
                    return `<td class="model-cell${dominantClass}">${item.model}</td>`;
                }).join('');
            } else {
                html += results.map((item, idx) => {
                    const baseClass = idx === gapBaseIndex ? ' base-col-cell' : '';
                    if (!item.hasSubscription && subscriptionKeys.includes(def.key)) {
                        return `<td class="number-cell${baseClass}">0</td>`;
                    }
                    return `<td class="number-cell${baseClass}">${fn(item[def.key])}</td>`;
                }).join('');
            }

            tr.innerHTML = html;
            tbody.appendChild(tr);
        });
    }

